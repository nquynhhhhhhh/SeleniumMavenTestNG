<!--        thread-count chỉ giới hạn cái parallel cho nên khi kết hợp classes với tests thì cần để trong test-->
        <classes>
            <class name="com.nhuquynh.Bai25_ParalleExecution.ChromeTest"/>
            <class name="com.nhuquynh.Bai25_ParalleExecution.EdgeTest"/>
        </classes>
    </test>

    <test name="Demo Parallel Testing By Classes 02" parallel="methods" thread-count="3">
        <classes>
            <class name="com.nhuquynh.Bai25_ParalleExecution.ChromeTest"/>
            <class name="com.nhuquynh.Bai25_ParalleExecution.EdgeTest"/>
        </classes>
    </test>
</suite>